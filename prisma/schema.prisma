datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

model User {
  id        Int      @id @default(autoincrement())
  name      String   @db.VarChar(100)
  email     String   @unique @db.VarChar(100)
  password  String   @db.VarChar(255)
  createdAt DateTime @default(now()) @map("created_at")
  orders    Order[]
  inventory Inventory[]

  @@map("users")
}

model Order {
  id                Int      @id @default(autoincrement())
  transactionNumber String?  @map("transaction_number") @db.VarChar(100)
  transactionDate   DateTime @map("transaction_date") @db.Date
  itemName          String   @map("item_name") @db.VarChar(255)
  quantity          Int      @default(0)
  price             Decimal  @default(0.00) @db.Decimal(10, 2)
  totalPrice        Decimal  @default(0.00) @db.Decimal(12, 2)
  status            String   @default("active") @db.VarChar(50)
  createdAt         DateTime @default(now()) @map("created_at")
  userId            Int      @map("user_id")
  user              User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("orders")
}
model Inventory {
  id                Int      @id @default(autoincrement())
  productName          String   @map("product_name") @db.VarChar(255)
  stock         Int      @default(0)
  demand          String   @map("demand") @db.VarChar(255)
  trend          String   @map("trend") @db.VarChar(255)
  userId            Int      @map("user_id")
  user              User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  @@map("inventory")
}
